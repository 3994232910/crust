# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY=自己生成
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=自己设置密码

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=数据库名
POSTGRES_USER=数据库用户名
POSTGRES_PASSWORD=数据库密码

SENTRY_DSN=

# ====================
# AI Model Configuration (LiteLLM)
# ====================
# 所有模型使用 LiteLLM 格式：provider/model-name
# 支持的 provider: openai, deepseek, anthropic, azure, google, etc.
# 完整列表：https://docs.litellm.ai/docs/providers
#
# API Key 必须在对应职能配置中显式指定，不再统一配置厂商 key

# 通用/纯文本模型：对话、总结、大纲生成、代码补全
# 示例：openai/gpt-4o-mini, deepseek/deepseek-chat, anthropic/claude-3-haiku
AI_MODEL_TEXT=openai/gpt-4o-mini
AI_MODEL_TEXT_API_KEY=sk-xxx     # 必须：该职能的 API Key
# 自定义 API 基础 URL（可选，用于本地部署或第三方兼容服务）
# 示例：https://api.openai.com/v1, https://api.deepseek.com/v1
AI_MODEL_TEXT_API_BASE=
# 设置为 false 可关闭对应功能，调用被禁用的功能将返回 503 错误
AI_ENABLE_CHAT=true              # 对话、总结、大纲、补全功能

# 视觉/多模态模型：图像分析、3D 标注等需要视觉理解的任务
# 示例：openai/gpt-4o, anthropic/claude-3-opus, google/gemini-pro-vision
AI_MODEL_VISION=openai/gpt-4o
AI_MODEL_VISION_API_KEY=         # 必须：该职能的 API Key（即使与 TEXT 相同也需要单独配置）
AI_MODEL_VISION_API_BASE=
AI_ENABLE_VISION=true            # 图像分析、3D 标注功能

# Embedding 模型：文本向量化
# 示例：openai/text-embedding-3-small, openai/text-embedding-3-large
AI_MODEL_EMBEDDING=openai/text-embedding-3-small
AI_MODEL_EMBEDDING_API_KEY=      # 必须：该职能的 API Key（即使与 TEXT 相同也需要单独配置）
AI_MODEL_EMBEDDING_API_BASE=
AI_EMBEDDING_DIM=1536            # 根据模型调整：text-embedding-3-small=1536, text-embedding-3-large=3072
AI_ENABLE_EMBEDDING=true         # 向量化、相似度推荐功能

# 默认生成参数
AI_DEFAULT_TEMPERATURE=0.3
AI_DEFAULT_MAX_TOKENS=2000


# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
